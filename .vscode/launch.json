{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Lwjgl3Launcher",
            "request": "launch",
            "mainClass": "io.github.cygnus_engine.lwjgl3.Lwjgl3Launcher",
            "projectName": "cygnus-engine-lwjgl3",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "gradle: lwjgl3 classes",
            "classPaths": [
                "$Auto",
                "${workspaceFolder}/lwjgl3/build/resources/main"
            ]
        },
        {
            "type": "java",
            "name": "Current File",
            "request": "launch",
            "mainClass": "${file}"
        }
    ]
}
